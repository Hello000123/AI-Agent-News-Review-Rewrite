# Required: create an API key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Current DeepSeek V4 model. Use deepseek-v4-pro when maximum quality is preferred.
DEEPSEEK_MODEL=deepseek-v4-flash

# Overall score at or above this value passes without an automatic rewrite.
REVIEW_PASS_SCORE=80

# Optional server-only settings.
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_MS=90000
